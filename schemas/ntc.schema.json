{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stevenbuglione.github.io/oas-cli-spec/schemas/ntc.schema.json",
  "title": "Normalized Tool Catalog",
  "type": "object",
  "required": ["catalogVersion", "generatedAt", "sourceFingerprint", "sources", "services", "tools", "effectiveViews"],
  "properties": {
    "catalogVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceFingerprint": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "uri", "provenance"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "uri": { "type": "string" },
          "provenance": {
            "type": "object",
            "required": ["method", "at"],
            "properties": {
              "method": { "type": "string" },
              "at": { "type": "string", "format": "date-time" },
              "fetches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["url", "fetchedAt", "method"],
                  "properties": {
                    "url": { "type": "string" },
                    "fetchedAt": { "type": "string", "format": "date-time" },
                    "method": { "type": "string" },
                    "requestMethod": { "type": "string" },
                    "statusCode": { "type": "integer" },
                    "cacheOutcome": { "type": "string" },
                    "etag": { "type": "string" },
                    "lastModified": { "type": "string" },
                    "cacheControl": { "type": "string" },
                    "expiresAt": { "type": "string", "format": "date-time" },
                    "stale": { "type": "boolean" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "alias", "sourceId", "title"],
        "properties": {
          "id": { "type": "string" },
          "alias": { "type": "string" },
          "sourceId": { "type": "string" },
          "title": { "type": "string" },
          "servers": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "serviceId", "method", "path", "group", "command", "safety"],
        "properties": {
          "id": { "type": "string" },
          "serviceId": { "type": "string" },
          "operationId": { "type": "string" },
          "method": { "type": "string" },
          "path": { "type": "string" },
          "group": { "type": "string" },
          "command": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" },
          "description": { "type": "string" },
          "hidden": { "type": "boolean" },
          "pathParams": { "type": "array", "items": { "type": "object" } },
          "flags": { "type": "array", "items": { "type": "object" } },
          "requestBody": {
            "type": "object",
            "required": ["required", "contentTypes"],
            "properties": {
              "required": { "type": "boolean" },
              "contentTypes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["mediaType", "schema"],
                  "properties": {
                    "mediaType": { "type": "string" },
                    "schema": { "type": "object" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "auth": { "type": "array", "items": { "type": "object" } },
          "safety": {
            "type": "object",
            "required": ["destructive", "readOnly", "requiresApproval", "idempotent"],
            "properties": {
              "destructive": { "type": "boolean" },
              "readOnly": { "type": "boolean" },
              "requiresApproval": { "type": "boolean" },
              "idempotent": { "type": "boolean" }
            }
          },
          "output": {
            "type": "object",
            "properties": {
              "defaultFields": { "type": "array", "items": { "type": "string" } },
              "redactions": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "pagination": {
            "type": "object",
            "properties": {
              "style": { "type": "string" },
              "cursorParam": { "type": "string" }
            },
            "additionalProperties": false
          },
          "retry": {
            "type": "object",
            "properties": {
              "recommended": { "type": "boolean" },
              "locationHeader": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "guidance": {
            "type": "object",
            "properties": {
              "whenToUse": { "type": "array", "items": { "type": "string" } },
              "avoidWhen": { "type": "array", "items": { "type": "string" } },
              "examples": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["goal", "command"],
                  "properties": {
                    "goal": { "type": "string" },
                    "command": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workflowId", "steps"],
        "properties": {
          "workflowId": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": true
      }
    },
    "effectiveViews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "mode", "tools"],
        "properties": {
          "name": { "type": "string" },
          "mode": { "type": "string" },
          "tools": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
